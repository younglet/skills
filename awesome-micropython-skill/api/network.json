      "sta_example": "import network\nwlan = network.WLAN(network.STA_IF)\nwlan.active(True)\nwlan.connect('MyWiFi', 'password')\nwhile not wlan.isconnected():\n    pass\nprint('IP:', wlan.ifconfig()[0])",
      "ap_example": "import network\nap = network.WLAN(network.AP_IF)\nap.config(ssid='ESP32-AP', password='12345678', security=network.WLAN.SEC_WPA2)\nap.active(True)\nprint('AP IP:', ap.ifconfig()[0])",
      "non_blocking_connect_example": "import network, time\nwlan = network.WLAN(network.STA_IF)\nwlan.active(True)\nwlan.connect('MyWiFi', 'password')\nfor _ in range(20):\n    if wlan.isconnected():\n        print('Connected!')\n        break\n    print('Connecting...')\n    time.sleep(0.5)\nelse:\n    print('Failed to connect')",
      "esp32_notes": [
        "ESP32 can run STA and AP simultaneously.",
        "Default hostname: 'esp32-<MAC>'. Change with wlan.config(dhcp_hostname='myname').",
        "Power saving: wlan.config(pm=network.WLAN.PM_PERFORMANCE) for better throughput.",
        "After deep sleep, Wi-Fi is re-initialized automatically on active(True).",
        "Maximum AP connections: 4 on original ESP32, 10 on ESP32-S3.",
        "Wi-Fi and ADC2 cannot be used simultaneously."
      ]
