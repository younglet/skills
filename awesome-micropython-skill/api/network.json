{
  "name": "network",
  "module": "network",
  "import": "import network",
  "version": "1.28.0",
  "category": "standard",
  "description": "Network configuration for Wi-Fi (WLAN), Ethernet (LAN), and PPP. Provides station (STA) and access point (AP) Wi-Fi modes.",
  "differences_from_cpython": [
    "This module does NOT exist in CPython. It is MicroPython-specific.",
    "No 'requests' module built-in. Install via mip: mip.install('requests').",
    "STA mode (station/client) and AP mode (access point) can run simultaneously on ESP32.",
    "Wi-Fi credentials persist across soft resets on ESP32."
  ],
  "module_functions": [
    {
      "name": "network.country",
      "signature": "country([code])",
      "returns": "str|None",
      "description": "Get or set Wi-Fi country code (e.g., 'CN', 'US'). Limits available channels."
    },
    {
      "name": "network.hostname",
      "signature": "hostname([name])",
      "returns": "str|None",
      "description": "Get or set network hostname (DHCP)."
    },
    {
      "name": "network.ipconfig",
      "signature": "ipconfig([if_id])",
      "returns": "tuple|None",
      "description": "Get IP config for given interface (STA_IF=0, AP_IF=1)."
    },
    {
      "name": "network.phy_mode",
      "signature": "phy_mode([mode])",
      "returns": "int|None",
      "description": "Get or set Wi-Fi PHY mode: MODE_11B, MODE_11G, MODE_11N, MODE_LR."
    }
  ],
