          "returns": "varies",
          "description": "Get detailed IP configuration including IPv6 data."
        },
        {
          "name": "WLAN.config",
          "signature": "config(param=None, value=None)",
          "parameters": [
            {
              "name": "param",
              "type": "str|None",
              "description": "'mac', 'ssid', 'channel', 'hidden', 'txpower', 'pm', 'protocol', 'reconnects', 'hostname', 'security', 'key' etc."
